# Copy to .env.local (gitignored) and fill in values to run live integration tests.
#
# Endlesss is a small operation. We do NOT hit live servers on every test run.
# All live integration tests are gated behind HOPPPER_RUN_LIVE_TESTS=1 even
# when credentials are present.

# Login credentials. The login form accepts either username or email.
HOPPPER_ENDLESSS_USERNAME=
HOPPPER_ENDLESSS_PASSWORD=

# Set to 1 to enable any live test. Default is off.
HOPPPER_RUN_LIVE_TESTS=

# Optional: a small jam ID (band############) used by the riff/stem integration
# test. Pick a jam you own with a low riff count to minimise server load.
HOPPPER_TEST_JAM_ID=
