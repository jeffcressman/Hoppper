{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hoppper",
  "version": "0.0.0",
  "identifier": "app.hoppper",
  "build": {
    "beforeDevCommand": "pnpm vite dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm vite build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "app": {
    "windows": [
      {
        "title": "Hoppper",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  }
}
